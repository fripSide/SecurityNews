<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{{ report_title | default('安全资讯周报') }} {{ date_range }}</title>
<style>
  @page {
    size: A4;
    margin: 2cm 2.5cm;
  }
  body {
    font-family: "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-size: 11pt;
    line-height: 1.7;
    color: #1a1a1a;
  }
  h1 {
    text-align: center;
    font-size: 22pt;
    margin-bottom: 0.2em;
    color: #0d1b2a;
  }
  .subtitle {
    text-align: center;
    font-size: 10pt;
    color: #666;
    margin-bottom: 2em;
  }
  h2 {
    font-size: 15pt;
    color: #1b4965;
    border-bottom: 2px solid #1b4965;
    padding-bottom: 0.3em;
    margin-top: 1.5em;
  }
  .article {
    margin-bottom: 1.2em;
    page-break-inside: avoid;
  }
  .article-title {
    font-size: 11.5pt;
    font-weight: bold;
    color: #0d1b2a;
    margin-bottom: 0.2em;
  }
  .article-title a {
    color: #1b4965;
    text-decoration: none;
  }
  .article-title a:hover {
    text-decoration: underline;
  }
  .article-intro {
    font-size: 10.5pt;
    color: #333;
    margin: 0;
  }
  .empty-section {
    color: #999;
    font-style: italic;
  }
  .footer {
    margin-top: 3em;
    text-align: center;
    font-size: 9pt;
    color: #999;
    border-top: 1px solid #ddd;
    padding-top: 1em;
  }
</style>
</head>
<body>

<h1>🛡️ {{ report_title | default('安全资讯周报') }}</h1>
<p class="subtitle">{{ date_range }}</p>

{% if sections.arxiv_cs_cr %}
<h2>📄 arXiv CS.CR 安全论文精选</h2>
{% for article in sections.arxiv_cs_cr %}
<div class="article">
  <p class="article-title"><a href="{{ article.link }}">{{ article.title }}</a></p>
  <p class="article-intro">{{ article.intro }}</p>
</div>
{% endfor %}
{% endif %}

{% if sections.arxiv_cs_ai %}
<h2>🤖 arXiv CS.AI 人工智能论文精选</h2>
{% for article in sections.arxiv_cs_ai %}
<div class="article">
  <p class="article-title"><a href="{{ article.link }}">{{ article.title }}</a></p>
  <p class="article-intro">{{ article.intro }}</p>
</div>
{% endfor %}
{% endif %}

{% if sections.bleepingcomputer %}
<h2>🔒 BleepingComputer 安全资讯</h2>
{% for article in sections.bleepingcomputer %}
<div class="article">
  <p class="article-title"><a href="{{ article.link }}">{{ article.title }}</a></p>
  <p class="article-intro">{{ article.intro }}</p>
</div>
{% endfor %}
{% endif %}

<div class="footer">
  由 SecurityNews 自动生成 · {{ generated_at }}
</div>

</body>
</html>
